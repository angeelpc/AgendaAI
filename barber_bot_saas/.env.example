# --- WhatsApp Cloud API (Meta / BSP) ---
WHATSAPP_TOKEN=tu_token_de_acceso
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_VERIFY_TOKEN=un_texto_secreto_que_tu_eliges

# --- Cerebro de IA (opcional) ---
# Si defines la clave, el bot usa IA con lenguaje natural.
# Si la dejas vacia, usa el motor de reglas offline (funciona sin internet).
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- Base de datos ---
DATABASE_URL=sqlite:///barber_bot.db

# --- Recordatorios ---
# Cuantas horas antes de la cita se manda el recordatorio (24 = el dia antes).
REMINDER_HOURS=24

# --- Superadmin de la plataforma ---
# Clave para dar de alta negocios nuevos (POST /api/negocios y pagina /alta).
# CAMBIALA por algo secreto en produccion.
PLATFORM_ADMIN_KEY=cambia-esta-clave-admin
