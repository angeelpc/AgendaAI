# --- WhatsApp Cloud API (Meta / BSP) ---
WHATSAPP_TOKEN=tu_token_de_acceso
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_VERIFY_TOKEN=un_texto_secreto_que_tu_eliges

# --- Cerebro de IA (opcional, elige UNO) ---
# Si defines una clave, el bot conversa como recepcionista con lenguaje natural.
# Si las dejas vacias, usa el motor de reglas offline (funciona sin internet).
#
# Opcion A: Google Gemini (tiene capa gratuita) -> https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
#
# Opcion B: Anthropic (Claude) -> https://console.anthropic.com
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- Base de datos ---
DATABASE_URL=sqlite:///barber_bot.db

# --- Recordatorios ---
# Cuantas horas antes de la cita se manda el recordatorio (24 = el dia antes).
REMINDER_HOURS=24

# --- Superadmin de la plataforma ---
# Clave para dar de alta negocios nuevos (POST /api/negocios y pagina /alta).
# CAMBIALA por algo secreto en produccion.
PLATFORM_ADMIN_KEY=cambia-esta-clave-admin

# --- Cobro de suscripciones (Mercado Pago) ---
# Si lo dejas vacio, el cobro corre en modo simulado (para pruebas locales).
MERCADOPAGO_ACCESS_TOKEN=
# URL publica del backend, para back_url y el webhook de Mercado Pago.
PUBLIC_BASE_URL=http://localhost:8000
